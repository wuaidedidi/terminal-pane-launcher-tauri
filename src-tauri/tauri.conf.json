{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Terminal Pane Launcher",
  "version": "0.1.0",
  "identifier": "com.local.terminal-pane-launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Terminal Pane Launcher",
        "width": 1560,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../templates/*": "templates/"
    },
    "icon": [
      "icons/icon.ico"
    ]
  }
}
